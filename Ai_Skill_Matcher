        "from pypdf import PdfReader\n",
        "\n",
        "def extract_pdf_text(pdf_file):\n",
        "\n",
        "    reader = PdfReader(pdf_file)\n",
        "\n",
        "    text = \"\"\n",
        "\n",
        "    for page in reader.pages:\n",
        "\n",
        "        page_text = page.extract_text()\n",
        "\n",
        "        if page_text:\n",
        "            text += page_text\n",
        "\n",
        "    return text"
      ],
